{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "strict": true,
    "allowJs": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@futelab/vop/sdk": ["packages/vop/src/sdk/index.ts"],
      "@futelab/vop-internal-protocol": ["packages/protocol/src/index.ts"],
      "@futelab/vop-internal-runtime": ["packages/runtime/src/index.ts"],
      "@futelab/vop-internal-panel": ["packages/panel/src/index.ts"]
    }
  }
}
