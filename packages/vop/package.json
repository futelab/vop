{
  "name": "@futelab/vop",
  "version": "0.1.0-alpha.0",
  "description": "Visible Operations Protocol for route-aware AI execution in real web apps.",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/futelab/vop.git",
    "directory": "packages/vop"
  },
  "homepage": "https://github.com/futelab/vop#readme",
  "bugs": {
    "url": "https://github.com/futelab/vop/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "ai",
    "automation",
    "browser",
    "copilot",
    "protocol",
    "runtime",
    "vop",
    "futelab"
  ],
  "files": [
    "dist",
    "bin",
    "scripts",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "vop": "./bin/vop.mjs"
  },
  "main": "./dist/vop/src/sdk/index.js",
  "types": "./dist/vop/src/sdk/index.d.ts",
  "exports": {
    "./sdk": {
      "types": "./dist/vop/src/sdk/index.d.ts",
      "import": "./dist/vop/src/sdk/index.js",
      "default": "./dist/vop/src/sdk/index.js",
      "require": "./dist/vop/src/sdk/index.js"
    },
    "./protocol": {
      "types": "./dist/vop/src/protocol.d.ts",
      "import": "./dist/vop/src/protocol.js",
      "default": "./dist/vop/src/protocol.js",
      "require": "./dist/vop/src/protocol.js"
    },
    "./runtime": {
      "types": "./dist/vop/src/runtime.d.ts",
      "import": "./dist/vop/src/runtime.js",
      "default": "./dist/vop/src/runtime.js",
      "require": "./dist/vop/src/runtime.js"
    },
    "./panel/react": {
      "types": "./dist/vop/src/panel/react.d.ts",
      "import": "./dist/vop/src/panel/react.js",
      "default": "./dist/vop/src/panel/react.js",
      "require": "./dist/vop/src/panel/react.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rm -rf dist tsconfig.build.tsbuildinfo && tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "generate": "node ./scripts/generate-vop.mjs"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.5",
    "react": "^19.2.0"
  }
}
